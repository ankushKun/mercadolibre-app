{
  "$schema": "https://registry.construct.computer/schemas/manifest.json",
  "name": "Mercado Libre",
  "description": "Resolve single or batch Mercado Libre product codes into canonical product page URLs and SEO slugs across Latin America without access tokens.",
  "author": {
    "name": "ankushKun",
    "url": "https://github.com/ankushKun"
  },
  "owners": ["ankushkun"],
  "icon": "ui/icon.png",
  "categories": ["shopping"],
  "tags": [
    "mercadolibre",
    "mercadolivre",
    "ecommerce",
    "latam",
    "product",
    "url-resolver"
  ],
  "ui": {
    "entry": "ui/index.html",
    "width": 720,
    "height": 640
  },
  "permissions": {
    "network": [
      "www.mercadolibre.com.ar",
      "www.mercadolivre.com.br",
      "www.mercadolibre.com.mx",
      "www.mercadolibre.cl",
      "www.mercadolibre.com.uy",
      "www.mercadolibre.com.ve",
      "www.mercadolibre.com.co",
      "www.mercadolibre.com.pe",
      "www.mercadolibre.com.ec",
      "www.mercadolibre.com.pa",
      "www.mercadolibre.com.py",
      "www.mercadolibre.com.do",
      "www.mercadolibre.com.bo",
      "www.mercadolibre.com.ni",
      "www.mercadolibre.co.cr",
      "www.mercadolibre.com.sv",
      "www.mercadolibre.com.hn",
      "www.mercadolibre.com.gt"
    ]
  }
}
